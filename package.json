{
  "name": "repo-blueprint-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "workflow:start": "node dist/workflow/entry.js",
    "workflow:dev": "tsx watch src/workflow/entry.ts",
    "dev": "tsx watch src/app/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src && tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@renderinc/sdk": "^0.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "render-dds": "github:R4ph-t/DDS",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.0.5"
  }
}
